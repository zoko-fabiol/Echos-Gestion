{
  "name": "echos-gestion",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "vite & electron .",
    "electron:build": "npm run build && electron-builder",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web"
  },
  "dependencies": {
    "@azure/msal-node": "^5.4.0",
    "@capacitor-community/text-to-speech": "^8.0.2",
    "@capacitor/app": "^8.1.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/share": "^8.0.1",
    "chart.js": "^4.4.4",
    "dexie": "^4.0.8",
    "dexie-react-hooks": "^1.1.7",
    "expo": "~57.0.4",
    "expo-secure-store": "~14.0.0",
    "expo-status-bar": "~57.0.0",
    "firebase": "^10.12.5",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.2",
    "lucide-react": "^0.435.0",
    "ms": "^2.1.3",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.3.1",
    "react-native": "0.86.0",
    "xlsx": "^0.18.5",
    "xlsx-js-style": "^1.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "postcss": "^8.4.41",
    "sharp": "^0.35.3",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vite": "^5.4.2"
  },
  "build": {
    "appId": "com.echos.gestion",
    "productName": "Echo Gestion",
    "copyright": "© 2026 Echos De chez Moi",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.cjs",
      "preload.js"
    ],
    "extraMetadata": {
      "main": "main.cjs"
    },
    "asar": true,
    "nodeGypRebuild": false,
    "win": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Echo Gestion",
      "deleteAppDataOnUninstall": false
    }
  }
}
